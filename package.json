{
  "name": "soulmate",
  "version": "1.0.0",
  "productName": "soulmate",
  "description": "A high-quality, zero-configuration Soulseek client for DJs.",
  "main": "./out/main/index.js",
  "author": "soulmate team",
  "homepage": "https://github.com/lhommeduchili/soulmate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lhommeduchili/soulmate.git"
  },
  "license": "GPL-3.0",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "test:e2e": "playwright test",
    "binaries:download": "ts-node scripts/download-binaries.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@microsoft/signalr": "^10.0.0",
    "better-sqlite3": "^12.6.2",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "ws": "^8.19.0",
    "yt-search": "^2.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.40.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^18.19.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/yt-search": "^2.10.3",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.23",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "playwright": "^1.40.0",
    "postcss": "^8.5.6",
    "prettier": "^3.1.0",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}